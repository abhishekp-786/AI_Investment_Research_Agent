{
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "env": {
    "GOOGLE_API_KEY": "@google_api_key",
    "TAVILY_API_KEY": "@tavily_api_key",
    "NEWS_API_KEY": "@news_api_key"
  },
  "functions": {
    "app/api/**": {
      "maxDuration": 60
    }
  }
}
